{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/checkin.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/checkin.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/src/checkin.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "TS Watch",
            "type": "shell",
            "command": "tsc",
            "args": [
                "-w",
                "-p",
                "${workspaceFolder}/src"
            ],
            "isBackground": true,
            "problemMatcher": [
                "$tsc-watch"
            ],
            "group": "build"
        }
    ]
}